# ============================
# .NET / Visual Studio
# ============================

# Build output (regenerated by `dotnet build`)
**/bin/
**/obj/

# Visual Studio workspace cache (machine-specific)
.vs/

# Per-user VS settings (personal IDE state, not code)
*.user
*.suo

# ============================
# Node / Vue / Vite
# ============================

# Downloaded npm packages (regenerated by `npm install`)
**/node_modules/

# Vite build output
**/dist/

# Vite cache
**/.vite/

# Local environment variables (for secrets, API keys, etc.)
.env
.env.local

# ============================
# OS junk
# ============================
.DS_Store
Thumbs.db
